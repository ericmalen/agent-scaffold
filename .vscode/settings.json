{
  // ===== Instructions =====
  // AGENTS.md at the repo root is the canonical repo-wide instructions file.
  // Copilot, Claude Code, Cursor, Codex, Aider, Gemini CLI, and others all
  // read it. CLAUDE.md is also discovered for cross-tool teammates.
  "chat.useAgentsMdFile": true,
  "chat.useNestedAgentsMdFiles": true,
  "chat.useClaudeMdFile": true,
  // Auto-attach .github/instructions/*.instructions.md whose applyTo glob
  // matches the active file.
  "chat.includeApplyingInstructions": true,
  // VS Code default (false). When true, VS Code follows Markdown links inside
  // .instructions.md / copilot-instructions.md and eagerly loads the targets
  // recursively. Off here for predictable context size. (Note: this setting
  // does NOT affect .agent.md or SKILL.md files — those use separate code
  // paths.)
  "chat.includeReferencedInstructions": false,

  // ===== Monorepo discovery =====
  // Discover customizations from parent folders up to the repo root so that a
  // package-level .github/ is picked up in addition to the root .github/.
  "chat.useCustomizationsInParentRepositories": true,

  // ===== Skills =====
  "chat.useAgentSkills": true,
  "chat.agentSkillsLocations": { ".github/skills": true },

  // ===== Agents / subagents =====
  // Enable pre/postRun hooks defined in a specific agent's frontmatter.
  "chat.useCustomAgentHooks": true,
  // Allow subagents to invoke subagents. Depth capped at 5 by VS Code; no
  // cycle detection. This scaffold still prefers flat orchestration as a
  // default — nesting is available for legitimate compositional cases.
  "chat.subagents.allowInvocationsFromSubagents": true,

  // ===== Terminal auto-approve (use cautiously) =====
  // Explicitly disabled so users opt in consciously. Leave the allow-list
  // empty until specific commands are reviewed and added.
  "chat.tools.terminal.enableAutoApprove": false,
  "chat.tools.terminal.autoApprove": []
}
