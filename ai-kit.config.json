{
  "schemaVersion": 1,
  "manifestName": ".claude/ai-kit.json",
  "source": {
    "repo": "https://dev.azure.com/ericmalen/ado-repo-tests/_git/ado-repo-tests"
  },
  "base": {
    "files": [
      "AGENTS.md",
      "CLAUDE.md",
      ".claude/settings.json",
      ".vscode/settings.json",
      ".claude/agents/README.md",
      ".claude/skills/README.md",
      ".github/prompts/README.md",
      ".github/prompts/_example.prompt.md",
      "docs/cross-tool-setup.md",
      "docs/migration.md",
      "docs/optimization.md"
    ],
    "skills": [
      "new-agent",
      "new-skill",
      "layer-agents",
      "migrate",
      "optimize"
    ],
    "agents": [
      "migrator",
      "optimizer"
    ]
  },
  "skills": {
    "git-conventions": {
      "path": ".claude/skills/git-conventions",
      "description": "Conventional Commits + team PR/branch conventions."
    }
  },
  "agents": {
    "example-reviewer": {
      "path": ".claude/agents/example-reviewer.md",
      "description": "Annotated example read-only reviewer agent."
    },
    "migrator": {
      "path": ".claude/agents/migrator.md",
      "description": "Resolves brownfield migration debt — semantically merges .ai-kit sidecars and updates the manifest. Invoke when finishing a brownfield migration."
    },
    "optimizer": {
      "path": ".claude/agents/optimizer.md",
      "description": "Audits installed AI assets for convention violations and applies a batch of fixes on single approval."
    }
  },
  "wiringFiles": [
    "AGENTS.md",
    "CLAUDE.md",
    ".claude/settings.json",
    ".vscode/settings.json"
  ],
  "brownfieldScanPaths": [
    "AGENTS.md",
    "CLAUDE.md",
    ".claude/",
    ".github/copilot-instructions.md",
    ".github/instructions/",
    ".github/prompts/",
    ".github/chatmodes/"
  ],
  "vscodeAiKeys": [
    "chat.useAgentsMdFile",
    "chat.useNestedAgentsMdFiles",
    "chat.useClaudeMdFile",
    "chat.useCustomizationsInParentRepositories",
    "chat.useAgentSkills",
    "chat.useCustomAgentHooks",
    "chat.subagents.allowInvocationsFromSubagents"
  ]
}
